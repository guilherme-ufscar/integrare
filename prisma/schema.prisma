generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id                     String        @id @default(cuid())
  name                   String
  slug                   String        @unique
  email                  String        @unique
  phone                  String?
  plan                   String        @default("BASICO") // BASICO, INTERMEDIARIO, COMPLIANCE_360
  status                 String        @default("PENDING") // PENDING, ACTIVE, SUSPENDED, CANCELLED
  stripeCustomerId       String?       @unique
  stripeSubscriptionId   String?       @unique
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  users    CompanyUser[]
  reports  Report[]
}

model CompanyUser {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("MANAGER") // MANAGER, ANALYST
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("ADMIN") // ADMIN, ANALYST
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Report {
  id           String   @id @default(cuid())
  protocol     String   @unique
  hashKey      String
  category     String
  title        String?
  description  String
  dateOccurred String?
  location     String?
  status       String   @default("NOVO") // NOVO, EM_TRIAGEM, EM_ANALISE, AGUARDANDO_INFO, EM_APURACAO, CONCLUIDO, ARQUIVADO
  severity     String   @default("NAO_CLASSIFICADO") // BAIXO, MEDIO, ALTO, CRITICO
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId  String?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  messages    Message[]
  attachments Attachment[]
}

model Message {
  id        String   @id @default(cuid())
  content   String
  role      String   // DENUNCIANTE, ADMIN
  createdAt DateTime @default(now())

  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  attachments Attachment[]
}

model Attachment {
  id        String   @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  String
  encrypted Boolean  @default(false)
  createdAt DateTime @default(now())

  reportId  String?
  report    Report?   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  messageId String?
  message   Message?  @relation(fields: [messageId], references: [id], onDelete: SetNull)
}
